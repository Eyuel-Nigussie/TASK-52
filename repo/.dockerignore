# Git
.git
.gitignore
.gitattributes

# Dependencies (re-installed in image)
vendor
node_modules

# Build artefacts
public/hot
public/build

# Storage runtime files (mounted from host in dev, created in container in prod)
storage/logs/*.log
storage/framework/cache/data
storage/framework/sessions
storage/framework/views
storage/app/public

# Environment files (injected at runtime)
.env
.env.backup
.env.production
.env.staging

# Database files
database/database.sqlite
*.sqlite

# Test / CI artefacts
.phpunit.result.cache
.phpunit.cache
coverage

# IDE / OS
.DS_Store
.idea
.vscode
.nova
.zed
*.swp
*.swo
Thumbs.db

# Docker-related (not needed inside the image)
docker-compose*.yml

# Docs (not needed at runtime)
docs
README.md
